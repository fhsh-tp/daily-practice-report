# FastAPI Application Settings
FASTAPI_APP_ENVIRONMENT=dev
SESSION_SECRET=your_super_secret_key_here

# Database Connection Settings (for FastAPI)
# The host should match the service name in docker-compose.yml
DB_HOST=mariadb
DB_PORT=3306

# MariaDB Settings (shared with docker-compose service configuration)
MARIADB_ROOT_PASSWORD=rootpassword
MARIADB_DATABASE=online_mall
MARIADB_USER=mall_user
MARIADB_PASSWORD=mall_user_password
